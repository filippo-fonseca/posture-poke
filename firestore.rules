rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if two users are accepted friends
    function isFriend(uid1, uid2) {
      let docId = uid1 < uid2 ? (uid1 + '_' + uid2) : (uid2 + '_' + uid1);
      return exists(/databases/$(database)/documents/friendships/$(docId)) &&
             get(/databases/$(database)/documents/friendships/$(docId)).data.status == "accepted";
    }

    // User documents
    match /users/{uid} {
      // Any authed user can read (needed for email lookup)
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;

      // Coaches subcollection
      match /coaches/{coachId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
        allow read: if request.auth != null && isFriend(request.auth.uid, uid);
      }

      // Sessions subcollection
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
        allow read: if request.auth != null && isFriend(request.auth.uid, uid);
      }
    }

    // Friendships collection
    match /friendships/{docId} {
      // Any authed user can read/get — the doc ID is deterministic and
      // contains both UIDs, so only someone who knows both UIDs can guess it.
      // The actual data is not sensitive (just status + UIDs).
      allow read: if request.auth != null;

      allow create: if request.auth != null &&
        (request.auth.uid in request.resource.data.users);

      allow update: if request.auth != null &&
        (request.auth.uid in resource.data.users);

      allow delete: if request.auth != null &&
        (request.auth.uid in resource.data.users);
    }
  }
}
