# SpineSync Environment Variables

# WebSocket server URL (default: ws://localhost:8000/ws)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ElevenLabs API key for voice alerts (optional)
# Get yours at: https://elevenlabs.io
NEXT_PUBLIC_ELEVENLABS_API_KEY=your_key_here

# Anthropic API key for AI coaching tips (optional)
# Get yours at: https://console.anthropic.com
NEXT_PUBLIC_ANTHROPIC_API_KEY=your_key_here
